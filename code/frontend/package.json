{
  "name": "carotis-ai-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "e2e": "playwright test",
    "e2e:chromium": "playwright test --project=chromium",
    "e2e:chromium:headed": "playwright test --project=chromium --headed",
    "e2e:chromium:visual": "playwright test e2e/chromium_visual_smoke.spec.ts --project=chromium",
    "analyze": "tsc -b && vite build --mode analyze"
  },
  "dependencies": {
    "@cornerstonejs/core": "^2.8.0",
    "@cornerstonejs/dicom-image-loader": "^2.8.0",
    "@cornerstonejs/tools": "^2.8.0",
    "@icr/polyseg-wasm": "^0.4.0",
    "@tanstack/react-query": "^5.56.2",
    "dicomweb-client": "^0.10.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "use-debounce": "^10.1.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.9.0",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "jsdom": "^25.0.0",
    "postcss": "^8.4.41",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.0.1",
    "vite": "^5.4.2",
    "vitest": "^2.1.0"
  }
}
