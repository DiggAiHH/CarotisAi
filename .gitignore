# Carotis-AI .gitignore
# Schützt vor versehentlichem Commit von Patientendaten, Secrets und Build-Artefakten.

# === Patientendaten — NIEMALS committen ===
data/
*.dcm
*.DCM
*.dicom
patient_*
*_phi.*
**/raw/
**/anonymized/
**/anon/
**/manifest*.csv
**/manifest*.json

# === Smoke-Test Artefakte ===
memory/runs/.smoke_*.md

# === Modell-Bundles — separat speichern, nicht im Repo ===
*.onnx
*.pth
*.pt
*.h5
*.tflite
*.ckpt
models/*.bin
models/*/checkpoints/

# === Audit-Trail-DBs (lokal nur am Klinikum-Server) ===
*.db
*.sqlite
*.sqlite3
audit/
audit_trail/

# === Decision-Trees (sind Trainings-Daten — separat verwaltet) ===
memory/decisions/*.json
memory/anomalies/*.json
# README in den Folders darf committed werden:
!memory/decisions/README.md
!memory/anomalies/README.md

# === Secrets & Konfiguration ===
.env
.env.local
.env.*.local
*.key
*.pem
*.pfx
secrets/
.doppler/

# === Python ===
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
*.cover
.hypothesis/
venv/
env/
.venv/

# === Node / Frontend (für dr-aroob-ki) ===
node_modules/
dist/
build/
.next/
.vite/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# === IDEs ===
.vscode/
!.vscode/settings.json.example
.idea/
*.swp
*.swo
*~

# === OS ===
.DS_Store
Thumbs.db
desktop.ini

# === Office Temporary Files ===
~$*.docx
~$*.pptx
~$*.xlsx

# === Office Output (v2-Files dürfen committed werden, andere nicht) ===
# Pre-Stride: Originale stays. Stride-Output _v2 bleibt.
*_temp.docx
*_draft.docx
*.tmp

# === Build & CI ===
coverage/
test-results/
.nyc_output/
*.tsbuildinfo

# === Deploy Keys (never commit!) ===
deploy/hetzner_deploy_key
deploy/hetzner_deploy_key.pub
